<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>I-Synergy.Framework.EventSourcing.Storage.S3</PackageId>
    <Description>AWS S3 implementation of IEventArchiveStorage for I-Synergy Event Sourcing</Description>
    <PackageTags>I-Synergy, Framework, EventSourcing, AWS, S3, Archive, CQRS</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsAotCompatible>false</IsAotCompatible>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="AWSSDK.S3" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\ISynergy.Framework.EventSourcing.Storage\ISynergy.Framework.EventSourcing.Storage.csproj" />
  </ItemGroup>
</Project>
