@page "/"
@page "/orders"
@rendermode InteractiveServer
@inject OrdersApiClient Api
@inject Sample.EventSourcing.Web.Services.TenantContext TenantCtx

<PageTitle>Orders — Event Sourcing Demo</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Orders</h1>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary" @onclick="RunArchiveAsync" disabled="@_archiving">
            @(_archiving ? "Archiving…" : "Run Archive")
        </button>
        <button class="btn btn-primary" @onclick="() => _showCreate = true">
            + Place Order
        </button>
    </div>
</div>

@if (_archiveMessage is not null)
{
    <div class="alert @(_archiveError ? "alert-danger" : "alert-success") alert-dismissible" role="alert">
        @_archiveMessage
        <button type="button" class="btn-close" aria-label="Close" @onclick="() => _archiveMessage = null"></button>
    </div>
}

@* ── Tenant selector ─────────────────────────────────────────────────────── *@
<div class="card mb-4 border-info">
    <div class="card-body py-2">
        <div class="row align-items-center g-2">
            <div class="col-auto">
                <label class="col-form-label fw-semibold text-info">Tenant ID</label>
            </div>
            <div class="col-md-4">
                <input class="form-control form-control-sm font-monospace"
                       @bind="_tenantId" @bind:event="oninput"
                       placeholder="11111111-1111-1111-1111-111111111111" />
            </div>
            <div class="col-auto">
                <button class="btn btn-sm btn-outline-info" @onclick="ApplyTenantAsync">Apply</button>
            </div>
            <div class="col text-muted small">
                Change tenant ID to see data isolation in action.
            </div>
        </div>
    </div>
</div>

@* ── Order list ──────────────────────────────────────────────────────────── *@
@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_orders.Count == 0)
{
    <div class="alert alert-light text-center">
        No orders yet. Place your first order above.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th class="text-end">Total</th>
                    <th>Placed At</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in _orders)
                {
                    <tr>
                        <td class="font-monospace small">@order.OrderId.ToString()[..8]…</td>
                        <td>@order.CustomerName</td>
                        <td class="text-end">@order.Total?.ToString("C")</td>
                        <td class="text-muted small">@order.PlacedAt.LocalDateTime.ToString("g")</td>
                        <td>
                            <a class="btn btn-sm btn-outline-secondary" href="/orders/@order.OrderId">
                                View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* ── Place Order modal ───────────────────────────────────────────────────── *@
@if (_showCreate)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Place New Order</h5>
                    <button type="button" class="btn-close" @onclick="() => _showCreate = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Customer Name</label>
                        <input class="form-control" @bind="_newCustomerName" placeholder="Alice Smith" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Total (€)</label>
                        <input type="number" class="form-control" @bind="_newTotal" min="0.01" step="0.01" />
                    </div>
                    @if (_createError is not null)
                    {
                        <div class="alert alert-danger py-2">@_createError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showCreate = false">Cancel</button>
                    <button class="btn btn-primary" @onclick="PlaceOrderAsync" disabled="@_placing">
                        @(_placing ? "Placing…" : "Place Order")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<OrderSummary> _orders = [];
    private bool _loading = true;
    private string? _error;

    private bool _showCreate;
    private string _newCustomerName = string.Empty;
    private decimal _newTotal = 99.99m;
    private bool _placing;
    private string? _createError;

    private string _tenantId = string.Empty;

    private bool _archiving;
    private string? _archiveMessage;
    private bool _archiveError;

    protected override async Task OnInitializedAsync()
    {
        _tenantId = TenantCtx.TenantId.ToString();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _orders = await Api.GetOrdersAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ApplyTenantAsync()
    {
        if (Guid.TryParse(_tenantId, out var id))
        {
            TenantCtx.TenantId = id;
            await LoadAsync();
        }
    }

    private async Task RunArchiveAsync()
    {
        _archiving = true;
        _archiveMessage = null;
        _archiveError = false;
        try
        {
            var result = await Api.RunArchiveAsync();
            _archiveMessage = result is null
                ? "Archive completed."
                : $"Archive complete: {result.StreamsArchived} stream(s), {result.EventsArchived} event(s) archived" +
                  (result.Errors > 0 ? $" ({result.Errors} error(s))" : ".");
        }
        catch (Exception ex)
        {
            _archiveError = true;
            _archiveMessage = $"Archive failed: {ex.Message}";
        }
        finally
        {
            _archiving = false;
        }
    }

    private async Task PlaceOrderAsync()
    {
        if (string.IsNullOrWhiteSpace(_newCustomerName))
        {
            _createError = "Customer name is required.";
            return;
        }

        _placing = true;
        _createError = null;
        try
        {
            await Api.PlaceOrderAsync(_newCustomerName, _newTotal);
            _showCreate = false;
            _newCustomerName = string.Empty;
            _newTotal = 99.99m;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _createError = ex.Message;
        }
        finally
        {
            _placing = false;
        }
    }
}
