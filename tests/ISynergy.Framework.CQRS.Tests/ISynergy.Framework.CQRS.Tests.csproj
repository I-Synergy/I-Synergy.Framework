<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<IsPackable>false</IsPackable>
		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <RootNamespace>ISynergy.Framework.CQRS</RootNamespace>
    <!-- Ensure source generators run and emit files to disk for inspection -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <RunAnalyzersDuringBuild>true</RunAnalyzersDuringBuild>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="CompareNETObjects" />
		<PackageReference Include="Microsoft.Extensions.Logging" />
		<PackageReference Include="Microsoft.NET.Test.Sdk" />
		<PackageReference Include="Moq" />
		<PackageReference Include="MSTest.TestFramework" />
		<PackageReference Include="MSTest.TestAdapter" />
		<PackageReference Include="Reqnroll" />
		<PackageReference Include="Reqnroll.MSTest" />
		<PackageReference Include="Reqnroll.Tools.MsBuild.Generation" />
		<PackageReference Include="coverlet.collector">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\..\src\ISynergy.Framework.CQRS\ISynergy.Framework.CQRS.csproj" />
		<!-- Directly reference the source generator as an Analyzer for local development.
		     When distributed via NuGet (analyzers/dotnet/cs/ folder), this is automatic. -->
		<ProjectReference
		  Include="..\..\src\ISynergy.Framework.CQRS.SourceGenerator\ISynergy.Framework.CQRS.SourceGenerator.csproj"
		  OutputItemType="Analyzer"
		  ReferenceOutputAssembly="false" />
	</ItemGroup>
</Project>
